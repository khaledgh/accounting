APP_NAME=Ecommerce Storefront
APP_PORT=8090
APP_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=erp_system
DB_SSLMODE=disable

JWT_SECRET=your-storefront-secret-key-change-me
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

STOREFRONT_URL=http://localhost:5174
API_BASE_URL=http://localhost:8090

# Image uploads / static files
IMAGE_BASE_URL=http://localhost:8090/uploads
UPLOAD_DIR=./uploads

# SMTP (for email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@bazarkon.com
